<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- ===============================
         BASE THEME PREVIMED (Material 3)
         =============================== -->
    <style name="Base.Theme.Previmed" parent="Theme.Material3.DayNight.NoActionBar">

        <!-- Color de la barra de estado -->
        <item name="android:statusBarColor">@color/AZUL_GENERAL</item>

        <!-- Fuerza a Material 3 a usar tus colores (evita el lila default) -->
        <item name="colorPrimary">@color/AZUL_GENERAL</item>
        <item name="colorOnPrimary">@color/white</item>

        <item name="colorPrimaryContainer">@color/AzulCielo_Prevemed</item>
        <item name="colorOnPrimaryContainer">@color/white</item>

        <item name="colorSecondary">@color/AzulCielo_Prevemed</item>
        <item name="colorOnSecondary">@color/white</item>

        <item name="colorSecondaryContainer">@color/AzulCielo_Prevemed</item>
        <item name="colorOnSecondaryContainer">@color/white</item>

        <!-- Colores de superficies -->
        <item name="colorSurface">@color/FONDO_PREVIMED</item>
        <item name="colorOnSurface">@color/negro_texto</item>

        <!-- Fondo general de toda la app -->
        <item name="android:windowBackground">@color/fondo_app</item>

    </style>

    <!-- Tu tema público -->
    <style name="Theme.Previmed" parent="Base.Theme.Previmed" />

    <!-- Indicador activo del BottomNavigation (sin el lila de M3) -->
    <style name="App.Custom.Indicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/AzulCielo_Prevemed</item>
        <item name="colorPrimaryContainer">@color/AZUL_GENERAL</item>
        <item name="colorSecondaryContainer">@color/AzulCielo_Prevemed</item>
    </style>

</resources>
