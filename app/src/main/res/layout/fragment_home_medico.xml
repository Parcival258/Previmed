<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    tools:context=".controller.medico.fragmentMedico.HomeMedicoFragment"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- 📸 Foto del médico -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardDoctorPhoto"
        android:layout_width="160dp"
        android:layout_height="160dp"
        app:cardCornerRadius="80dp"
        app:cardElevation="6dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/cardInfo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_chainStyle="packed">

        <ImageView
            android:id="@+id/imgDoctor"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:contentDescription="Foto del médico" />
    </androidx.cardview.widget.CardView>

    <!-- 💼 Tarjeta de información -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardInfo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="5dp"
        app:layout_constraintTop_toBottomOf="@id/cardDoctorPhoto"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/buttonsContainer">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp"
            android:gravity="center_horizontal">

            <!-- 🩺 Nombre -->
            <TextView
                android:id="@+id/txtName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dr(a). Nombre Apellido"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@android:color/black"
                android:gravity="center"
                android:layout_marginBottom="6dp" />

            <!-- 💊 Especialidad -->
            <TextView
                android:id="@+id/txtSpecialty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Médico general"
                android:textSize="15sp"
                android:textColor="@android:color/darker_gray"
                android:gravity="center"
                android:layout_marginBottom="12dp" />

            <!-- Separador -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                android:layout_marginBottom="16dp" />

            <!-- 🩵 Mensaje motivacional -->
            <TextView
                android:id="@+id/txtAbout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Acerca de:\nRecuerda que nuestros pacientes son muy importantes. Brinda siempre una atención de calidad."
                android:textSize="16sp"
                android:textColor="@android:color/black"
                android:gravity="center"
                android:paddingVertical="8dp"
                android:lineSpacingExtra="6dp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- 🔘 Botones -->
    <LinearLayout
        android:id="@+id/buttonsContainer"
        android:orientation="vertical"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Botón disponibilidad -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnEstado"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Cambiar disponibilidad"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:background="@drawable/btn_degradado" />

        <!-- Botón estado activo/inactivo -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnActivo"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="12dp"
            android:text="Cambiar estado"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:background="@drawable/btn_degradado" />

        <!-- Botón cerrar sesión -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="12dp"
            android:text="Cerrar sesión"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:background="@drawable/btn_degradado" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
