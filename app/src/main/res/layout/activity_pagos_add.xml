<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F8FA"
    android:fitsSystemWindows="true"
    tools:context=".view.pagos.PagosAdd">

    <!-- 🔵 HEADER AZUL -->
    <LinearLayout
        android:id="@+id/headerPagos"
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="@drawable/bg_header_contrato"
        android:elevation="8dp">

        <TextView
            android:id="@+id/tvHeaderTitulo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Registro de Pago"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:textSize="26sp"
            android:gravity="center" />
    </LinearLayout>

    <!-- 📜 CONTENIDO PRINCIPAL -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="20dp"
        android:layout_marginTop="95dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <!-- TARJETA -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:elevation="6dp"
                android:background="@drawable/bg_formulario"
                android:layout_marginBottom="24dp">

                <!-- TITULAR -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Titular (Paciente)"
                    android:textStyle="bold"
                    android:textColor="#555"
                    android:layout_marginBottom="6dp" />

                <AutoCompleteTextView
                    android:id="@+id/etBuscarTitular"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Buscar por nombre o cédula..."
                    android:padding="12dp"
                    android:inputType="text"
                    android:background="@drawable/bg_spinner"
                    android:layout_marginBottom="16dp" />

                <!-- 📷 SUBIR FOTO -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Comprobante (Foto)"
                    android:textStyle="bold"
                    android:textColor="#555"
                    android:layout_marginBottom="10dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:weightSum="2"
                    android:layout_marginBottom="20dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTomarFoto"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Tomar Foto"
                        android:textAllCaps="false"
                        android:textStyle="bold"
                        android:textColor="@android:color/white"
                        android:backgroundTint="#1976D2"
                        android:paddingVertical="12dp"
                        app:cornerRadius="14dp"
                        android:elevation="6dp" />

                    <View
                        android:layout_width="12dp"
                        android:layout_height="wrap_content" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSubirFoto"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Elegir Imagen"
                        android:textAllCaps="false"
                        android:textStyle="bold"
                        android:textColor="@android:color/white"
                        android:backgroundTint="#0288D1"
                        android:paddingVertical="12dp"
                        app:cornerRadius="14dp"
                        android:elevation="6dp" />
                </LinearLayout>

                <!-- 📸 PREVIEW -->
                <ImageView
                    android:id="@+id/ivPreview"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:layout_marginBottom="20dp"
                    android:scaleType="centerCrop"
                    android:background="#E0E0E0"
                    android:contentDescription="Vista previa del comprobante" />

                <!-- FECHAS -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2"
                    android:layout_marginBottom="12dp">

                    <!-- FECHA INICIO -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Fecha de Inicio"
                            android:textStyle="bold"
                            android:textColor="#555"
                            android:layout_marginBottom="6dp" />

                        <EditText
                            android:id="@+id/etFechaInicio"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Seleccionar fecha"
                            android:padding="10dp"
                            android:focusable="false"
                            android:clickable="true"
                            android:background="@drawable/bg_spinner" />
                    </LinearLayout>

                    <View
                        android:layout_width="12dp"
                        android:layout_height="match_parent" />

                    <!-- FECHA FIN -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Fecha de Fin"
                            android:textStyle="bold"
                            android:textColor="#555"
                            android:layout_marginBottom="6dp" />

                        <EditText
                            android:id="@+id/etFechaFin"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Seleccionar fecha"
                            android:padding="10dp"
                            android:focusable="false"
                            android:clickable="true"
                            android:background="@drawable/bg_spinner" />
                    </LinearLayout>
                </LinearLayout>

                <!-- FECHA PAGO -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fecha de Pago"
                    android:textStyle="bold"
                    android:textColor="#555"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/etFechaPago"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Seleccionar fecha"
                    android:padding="10dp"
                    android:focusable="false"
                    android:clickable="true"
                    android:background="@drawable/bg_spinner"
                    android:layout_marginBottom="12dp" />

                <!-- FORMA PAGO -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Forma de Pago"
                    android:textStyle="bold"
                    android:textColor="#555"
                    android:layout_marginBottom="6dp" />

                <Spinner
                    android:id="@+id/spinnerFormaPago"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_spinner"
                    android:paddingVertical="10dp"
                    android:paddingHorizontal="12dp"
                    android:layout_marginBottom="12dp" />

                <!-- RECIBO -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Número de Recibo"
                    android:textStyle="bold"
                    android:textColor="#555"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/etNumeroRecibo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Ingresar número"
                    android:padding="10dp"
                    android:inputType="number"
                    android:background="@drawable/bg_spinner"
                    android:layout_marginBottom="12dp" />

                <!-- MONTO -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Monto"
                    android:textStyle="bold"
                    android:textColor="#555"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/etMonto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Ingresar monto"
                    android:padding="10dp"
                    android:inputType="numberDecimal"
                    android:background="@drawable/bg_spinner"
                    android:layout_marginBottom="16dp" />

            </LinearLayout>

            <!-- BOTÓN GUARDAR -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGuardar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Registrar Pago"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:backgroundTint="#43A047"
                app:cornerRadius="14dp"
                android:paddingVertical="14dp"
                android:elevation="8dp"
                android:layout_marginBottom="40dp" />
        </LinearLayout>

    </ScrollView>

</FrameLayout>
