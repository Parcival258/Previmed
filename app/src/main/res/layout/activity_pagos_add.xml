<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="10dp"
    tools:context=".controller.asesor.PagosAdd">

    <!-- Título de la vista -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:gravity="center"
        android:text="Agregar Pago"
        android:textSize="30sp"
        android:layout_marginTop="20dp"/>

    <!-- Imagen del botón -->
    <ImageButton
        android:layout_width="140dp"
        android:layout_height="120dp"
        android:layout_gravity="center"
        android:background="@drawable/ic_img"/>

    <!-- Fila de fechas: Inicio y Fin -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <EditText
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Fecha Inicio"
            android:inputType="date"/>

        <EditText
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:inputType="date"
            android:hint="Fecha Fin"/>
    </LinearLayout>

    <!-- Fila de Spinners: Titular y Forma de Pago -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">


<LinearLayout
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_weight="1">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Selecciona el titular"
        android:textStyle="bold"/>

    <Spinner
        android:id="@+id/spinner_titular"
        android:layout_width="150dp"
        android:layout_height="40dp"
        android:layout_weight="1" />
    </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_weight="1">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:text="Selecciona forma de pago"/>
        <Spinner
            android:id="@+id/spinner_forma_pago"
            android:layout_width="150dp"
            android:layout_height="40dp"
            android:layout_weight="1"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Campo de monto -->
    <EditText
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:inputType="numberDecimal"
        android:hint="Monto"/>

    <Button
        android:id="@+id/btn_save_pago"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="60dp"
        android:textSize="20dp"
        android:text="Agregar"/>

</LinearLayout>
