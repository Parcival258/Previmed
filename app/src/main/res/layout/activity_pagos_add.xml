<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F8FA"
    android:padding="20dp"
    android:paddingTop="?attr/actionBarSize"
    tools:context=".view.pagos.PagosAdd">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- TITULO -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Registro de Pago"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#222222"
            android:layout_marginBottom="20dp" />

        <!-- CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_rounded"
            android:padding="20dp"
            android:elevation="6dp"
            android:layout_marginBottom="24dp">

            <!-- TITULAR -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Titular (Paciente)"
                android:textStyle="bold"
                android:textColor="#555"
                android:layout_marginBottom="6dp" />

            <Spinner
                android:id="@+id/spinnerTitular"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_spinner"
                android:paddingVertical="10dp"
                android:paddingHorizontal="12dp"
                android:layout_marginBottom="16dp" />

            <!-- FECHAS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="12dp">

                <!-- FECHA INICIO -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fecha de Inicio"
                        android:textStyle="bold"
                        android:textColor="#555"
                        android:layout_marginBottom="6dp" />

                    <EditText
                        android:id="@+id/etFechaInicio"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Seleccionar fecha"
                        android:padding="10dp"
                        android:focusable="false"
                        android:clickable="true"
                        android:background="@drawable/bg_spinner" />
                </LinearLayout>

                <View
                    android:layout_width="12dp"
                    android:layout_height="match_parent" />

                <!-- FECHA FIN -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fecha de Fin"
                        android:textStyle="bold"
                        android:textColor="#555"
                        android:layout_marginBottom="6dp" />

                    <EditText
                        android:id="@+id/etFechaFin"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Seleccionar fecha"
                        android:padding="10dp"
                        android:focusable="false"
                        android:clickable="true"
                        android:background="@drawable/bg_spinner" />
                </LinearLayout>
            </LinearLayout>

            <!-- FECHA DE PAGO -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fecha de Pago"
                android:textStyle="bold"
                android:textColor="#555"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etFechaPago"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Seleccionar fecha"
                android:padding="10dp"
                android:focusable="false"
                android:clickable="true"
                android:background="@drawable/bg_spinner"
                android:layout_marginBottom="12dp" />

            <!-- FORMA DE PAGO -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Forma de Pago"
                android:textStyle="bold"
                android:textColor="#555"
                android:layout_marginBottom="6dp" />

            <Spinner
                android:id="@+id/spinnerFormaPago"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_spinner"
                android:paddingVertical="10dp"
                android:paddingHorizontal="12dp"
                android:layout_marginBottom="12dp"
                android:enabled="true"
                android:alpha="1.0" />

            <!-- NUMERO RECIBO -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Número de Recibo"
                android:textStyle="bold"
                android:textColor="#555"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etNumeroRecibo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Ingresar número"
                android:padding="10dp"
                android:inputType="number"
                android:background="@drawable/bg_spinner"
                android:layout_marginBottom="12dp" />

            <!-- MONTO -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Monto"
                android:textStyle="bold"
                android:textColor="#555"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/etMonto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Ingresar monto"
                android:padding="10dp"
                android:inputType="numberDecimal"
                android:background="@drawable/bg_spinner"
                android:layout_marginBottom="16dp" />
        </LinearLayout>

        <!-- BOTÓN GUARDAR -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGuardar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Registrar Pago"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:backgroundTint="#43A047"
            app:cornerRadius="14dp"
            android:paddingVertical="14dp"
            android:elevation="8dp"
            android:layout_marginBottom="40dp" />

    </LinearLayout>
</ScrollView>
