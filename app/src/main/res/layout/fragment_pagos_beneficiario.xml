<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".controller.pacientes.fragmentBeneficiario.PagosBeneficiarioFragment"
    android:orientation="vertical"
    android:background="#F5F7FB">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="93dp"
        android:background="@drawable/bg_header_contrato"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp"
        android:paddingTop="40dp">

        <TextView
            android:id="@+id/numerocontrato"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Número de contrato"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:fontFamily="sans-serif-medium"
            android:elevation="2dp"/>
    </LinearLayout>

    <androidx.cardview.widget.CardView
        android:id="@+id/cardProgresoPagos"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="16dp"
        app:cardUseCompatPadding="true"
        app:cardElevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvTituloProgreso"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Progreso de pagos"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#111827"
                android:layout_gravity="center_horizontal" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvFechaInicioPagos"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Inicio pagos"
                    android:textSize="12sp"
                    android:textColor="#6B7280" />

                <TextView
                    android:id="@+id/tvFechaFinPagos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fin pagos"
                    android:textSize="12sp"
                    android:textColor="#6B7280" />
            </LinearLayout>

            <ProgressBar
                android:id="@+id/progressPagos"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="10dp"
                android:layout_marginTop="12dp"
                android:max="100"
                android:progress="0"
                android:progressDrawable="@android:drawable/progress_horizontal" />


        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="16dp"
        app:cardUseCompatPadding="true"
        app:cardElevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingVertical="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:textStyle="bold"
                    android:text="Fecha inicio:" />

                <TextView
                    android:id="@+id/tvFechaInicioContrato"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="02-02-2025" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingVertical="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Fecha fin:"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvFechaFinContrato"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="02-02-2026" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingVertical="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Próximo pago:"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvProximoPago"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="02-05-2025" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingVertical="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Titular de la membresía:"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvTitular"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Juan Pérez" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingVertical="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Plan:"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvPlan"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Premium" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingVertical="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Beneficios:"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvBeneficios"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Cuatro integrantes" />
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>
