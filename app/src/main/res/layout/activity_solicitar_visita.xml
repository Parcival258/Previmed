<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#EFF1FF"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <ImageView
            android:layout_width="130dp"
            android:layout_height="100dp"
            android:layout_marginTop="35dp"
            android:src="@drawable/logo" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Solicita tu visita"
            android:textStyle="bold"
            android:textSize="20sp"
            android:textColor="#000000"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="24dp" />

        <!-- Teléfono -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Teléfono *"
            android:textColor="#000000"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/edTelefono"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="phone"
            android:padding="12dp"
            android:background="@color/white"
            android:backgroundTint="#CCCCCC"
            android:textColor="#000000"
            android:layout_marginBottom="16dp"
            android:elevation="2dp"
            android:hint="Ej: 3201234567" />

        <!-- Fecha -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Fecha de visita *"
            android:textColor="#000000"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/edFecha"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="AAAA-MM-DD"
            android:inputType="date"
            android:padding="12dp"
            android:background="@color/white"
            android:backgroundTint="#CCCCCC"
            android:textColor="#000000"
            android:layout_marginBottom="16dp"
            android:elevation="2dp" />

        <!-- Dirección -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Dirección *"
            android:textColor="#000000"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/edDireccion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:background="@color/white"
            android:backgroundTint="#CCCCCC"
            android:textColor="#000000"
            android:layout_marginBottom="16dp"
            android:elevation="2dp"
            android:hint="Ej: Calle 12 #34-56" />

        <!-- Descripción -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Descripción *"
            android:textColor="#000000"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/edDescripcion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:background="@color/white"
            android:backgroundTint="#CCCCCC"
            android:textColor="#000000"
            android:layout_marginBottom="16dp"
            android:elevation="2dp"
            android:hint="Motivo de la visita" />

        <!-- Selector de barrio -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Barrio *"
            android:textColor="#000000"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <Spinner
            android:id="@+id/spinnerBarrios"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/white"
            android:padding="10dp" />

        <!-- Médico -->
        <CheckBox
            android:id="@+id/checkMedico"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Deseo médico en específico"
            android:textColor="#000000"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvLabelMedico"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Seleccione médico"
            android:textColor="#000000"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"
            android:visibility="gone" />

        <Spinner
            android:id="@+id/spinnerMedicos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/white"
            android:padding="10dp"
            android:enabled="false"
            android:visibility="gone" />

        <!-- Botones -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnSolicitar"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="32dp"
            android:background="@drawable/btn_fondo_previmed"
            android:text="Solicitar"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_Cancelar"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/btn_cancelar"
            android:text="Cancelar"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvMensajes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#000000"
            android:layout_marginTop="16dp"
            android:padding="8dp" />

    </LinearLayout>
</ScrollView>