<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="10dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="6dp"
    app:cardUseCompatPadding="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:background="@android:color/white">

        <!-- 🔹 Encabezado: Fecha y Nombre -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="8dp">

            <!-- 🔹 Box de Fecha -->
            <LinearLayout
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:background="@color/AZUL_GENERAL"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="6dp"
                android:layout_marginEnd="12dp"
                android:clipToOutline="true">

                <TextView
                    android:id="@+id/txtDiaGrande"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="10"
                    android:textColor="@android:color/white"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtMes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Octubre"
                    android:textColor="@android:color/white"
                    android:textSize="10sp" />
            </LinearLayout>

            <!-- 🔹 Información Paciente/Médico -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:paddingStart="4dp"
                android:paddingEnd="8dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtPacienteNombre"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Paciente/Médico"
                    android:textSize="15sp"
                    android:textColor="@android:color/black"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/txtDireccion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="📍 Dirección"
                    android:textSize="12sp"
                    android:textColor="#555555"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/txtFecha"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="🗓 Fecha visita"
                    android:textSize="12sp"
                    android:textColor="#555555" />
            </LinearLayout>
        </LinearLayout>

        <!-- 🔹 Divisor -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#EEEEEE"
            android:layout_marginVertical="8dp" />

        <!-- 🔹 Fila de Botones Horizontal -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:spacing="8dp"
            android:paddingHorizontal="5dp">

            <!-- 🔹 Botón Ver detalles -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVerDetalles"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="Ver detalles"
                android:textSize="11sp"
                android:textAllCaps="false"
                android:paddingHorizontal="8dp"
                app:cornerRadius="18dp"
                app:strokeWidth="1.5dp"
                app:strokeColor="@color/AZUL_GENERAL"
                app:iconPadding="4dp"
                app:icon="@drawable/ic_visibility"
                app:iconTint="@color/AZUL_GENERAL"
                app:backgroundTint="@android:color/white"
                android:textColor="@color/AZUL_GENERAL" />

            <!-- 🔹 Botón Iniciar/Finalizar o Cancelar -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnIniciarFinalizar"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="Iniciar"
                android:textSize="11sp"
                android:textAllCaps="false"
                android:paddingHorizontal="8dp"
                app:cornerRadius="18dp"
                app:strokeWidth="1.5dp"
                app:strokeColor="@color/AZUL_GENERAL"
                app:iconPadding="4dp"
                app:backgroundTint="@android:color/white"
                android:textColor="@color/AZUL_GENERAL" />
        </LinearLayout>

        <!-- 🔹 Divisor -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#EEEEEE"
            android:layout_marginVertical="8dp" />

        <!-- 🔹 Sección Detalles (Oculta por defecto) -->
        <LinearLayout
            android:id="@+id/cardDetalles"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp"
            android:visibility="gone"
            android:background="#F9FAFB">

            <TextView
                android:id="@+id/txtBarrio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="🏘 Barrio:"
                android:textSize="13sp"
                android:textColor="#333333"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/txtTelefono"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="☎️ Teléfono:"
                android:textSize="13sp"
                android:textColor="#333333" />

            <TextView
                android:id="@+id/txtDescripcion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="🧾 Descripción:"
                android:textSize="13sp"
                android:textColor="#333333"
                android:maxLines="2"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/txtEstado"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📋 Estado:"
                android:textSize="13sp"
                android:textColor="#333333" />
        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>