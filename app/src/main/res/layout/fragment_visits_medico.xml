<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white"
    tools:context=".controller.medico.fragmentMedico.VisitsMedico">

    <!-- 🔹 Título centrado con espacio superior -->
    <TextView
        android:id="@+id/txtTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🩺 Visitas Pendientes"
        android:background="@drawable/bg_header_contrato"
        android:gravity="center"
        android:textStyle="bold"
        android:textSize="22sp"
        android:paddingTop="55dp"
        android:paddingBottom="40dp"
        android:paddingHorizontal="22dp"
        android:textColor="@android:color/black" />

    <!-- 🔹 Lista de visitas -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerVisitas"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="8dp"
        android:scrollbars="vertical"
        tools:listitem="@layout/item_visita_pendiente" />
</LinearLayout>