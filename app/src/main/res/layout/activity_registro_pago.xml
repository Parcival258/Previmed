<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".controller.asesor.RegistrarPagoActivity">

    <!-- 🔵 TÍTULO SUPERIOR -->
    <TextView
        android:id="@+id/tvTituloPago"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Registrar Pago"
        android:textColor="@color/black"
        android:textStyle="bold"
        android:textSize="26sp"
        android:paddingVertical="18dp"
        android:gravity="center"
        android:background="@color/white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- 📜 SCROLL -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="16dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/tvTituloPago"
        app:layout_constraintBottom_toTopOf="@id/layoutBotonesPago"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 🧾 TARJETA REDONDEADA -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_formulario"
                android:padding="20dp"
                android:elevation="10dp"
                android:layout_marginTop="10dp"
                android:layout_marginHorizontal="6dp">

                <!-- 💵 Monto -->
                <TextView
                    android:text="Monto del pago"
                    android:textColor="@color/AZUL_GENERAL"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <EditText
                    android:id="@+id/etMonto"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="8dp"
                    android:hint="Ej: 150000"
                    android:padding="14dp"
                    android:background="@drawable/input_style"
                    android:inputType="numberDecimal"/>

                <!-- 📅 Fecha Inicio -->
                <TextView
                    android:text="Fecha de inicio"
                    android:textColor="@color/AZUL_GENERAL"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginTop="20dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <EditText
                    android:id="@+id/etFechaInicio"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="8dp"
                    android:hint="Selecciona fecha..."
                    android:focusable="false"
                    android:clickable="true"
                    android:padding="14dp"
                    android:background="@drawable/input_style"/>

                <!-- 📅 Fecha Fin -->
                <TextView
                    android:text="Fecha de fin"
                    android:textColor="@color/AZUL_GENERAL"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginTop="20dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <EditText
                    android:id="@+id/etFechaFin"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="8dp"
                    android:hint="Selecciona fecha..."
                    android:focusable="false"
                    android:clickable="true"
                    android:padding="14dp"
                    android:background="@drawable/input_style"/>

                <!-- 📅 Fecha Pago -->
                <TextView
                    android:text="Fecha de pago"
                    android:textColor="@color/AZUL_GENERAL"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginTop="20dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <EditText
                    android:id="@+id/etFechaPago"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="8dp"
                    android:hint="Selecciona fecha..."
                    android:focusable="false"
                    android:clickable="true"
                    android:padding="14dp"
                    android:background="@drawable/input_style"/>

                <!-- ℹ INFO MEMBRESIA -->
                <TextView
                    android:id="@+id/tvMembresia"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:layout_marginTop="20dp"
                    android:background="#E3F2FD"
                    android:textColor="#0D47A1"
                    android:text="Membresía ID: -"/>

                <TextView
                    android:id="@+id/tvFormaPago"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:layout_marginTop="10dp"
                    android:background="#E3F2FD"
                    android:textColor="#0D47A1"
                    android:text="Forma de pago: -"/>

                <ProgressBar
                    android:id="@+id/pbCargargandu"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="20dp"
                    style="?android:attr/progressBarStyleLarge"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- 🔘 BOTONES INFERIORES -->
    <LinearLayout
        android:id="@+id/layoutBotonesPago"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/white"
        android:padding="16dp"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnRegistrarPago"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Registrar Pago"
            android:textStyle="bold"
            android:padding="14dp"
            android:backgroundTint="@color/AZUL_GENERAL"
            android:textColor="@android:color/white"/>

        <Button
            android:id="@+id/btnNuevoPago"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:padding="14dp"
            android:text="Nuevo Registro"
            android:textColor="@android:color/white"
            android:backgroundTint="#4CAF50"
            android:layout_marginTop="12dp"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
