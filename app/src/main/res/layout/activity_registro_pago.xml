<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F4F8"
    tools:context=".controller.asesor.RegistrarPagoActivity">

    <!-- 🔷 Encabezado -->
    <TextView
        android:id="@+id/tvTituloPago"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Registrar Pago"
        android:textColor="@android:color/white"
        android:background="#1976D2"
        android:textStyle="bold"
        android:textSize="20sp"
        android:gravity="center"
        android:padding="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 🔽 Contenedor principal -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="14dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/tvTituloPago"
        app:layout_constraintBottom_toTopOf="@id/layoutBotonesPago"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 🧾 Tarjeta general -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@android:color/white"
                android:padding="18dp"
                android:elevation="4dp"
                android:layout_marginBottom="20dp"
                android:layout_marginTop="10dp"
                android:backgroundTint="#FFFFFF"
                android:clipToPadding="false"
                android:layout_marginHorizontal="6dp">

                <!-- 💵 Monto -->
                <TextView
                    android:text="Monto del pago"
                    android:textColor="#1976D2"
                    android:textStyle="bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <EditText
                    android:id="@+id/etMonto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:hint="Ej: 150000"
                    android:padding="12dp"
                    android:background="@android:color/white"
                    android:elevation="2dp"
                    android:inputType="numberDecimal" />

                <!-- 📅 Fecha Inicio -->
                <TextView
                    android:text="Fecha de inicio"
                    android:textColor="#1976D2"
                    android:textStyle="bold"
                    android:layout_marginTop="16dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <EditText
                    android:id="@+id/etFechaInicio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:hint="Selecciona fecha..."
                    android:focusable="false"
                    android:clickable="true"
                    android:padding="12dp"
                    android:background="@android:color/white"
                    android:elevation="2dp" />

                <!-- 📅 Fecha Fin -->
                <TextView
                    android:text="Fecha de fin"
                    android:textColor="#1976D2"
                    android:textStyle="bold"
                    android:layout_marginTop="16dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <EditText
                    android:id="@+id/etFechaFin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:hint="Selecciona fecha..."
                    android:focusable="false"
                    android:clickable="true"
                    android:padding="12dp"
                    android:background="@android:color/white"
                    android:elevation="2dp" />

                <!-- 📅 Fecha Pago -->
                <TextView
                    android:text="Fecha de pago"
                    android:textColor="#1976D2"
                    android:textStyle="bold"
                    android:layout_marginTop="16dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <EditText
                    android:id="@+id/etFechaPago"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:hint="Selecciona fecha..."
                    android:focusable="false"
                    android:clickable="true"
                    android:padding="12dp"
                    android:background="@android:color/white"
                    android:elevation="2dp" />

                <!-- ℹ Información recibida -->
                <TextView
                    android:id="@+id/tvMembresia"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:layout_marginTop="20dp"
                    android:background="#E3F2FD"
                    android:textColor="#0D47A1"
                    android:text="Membresía ID: -" />

                <TextView
                    android:id="@+id/tvFormaPago"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:layout_marginTop="10dp"
                    android:background="#E3F2FD"
                    android:textColor="#0D47A1"
                    android:text="Forma de pago: -" />

                <ProgressBar
                    android:id="@+id/pbCargargandu"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="20dp"
                    style="?android:attr/progressBarStyleLarge"/>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- 🟩 Botones inferiores -->
    <LinearLayout
        android:id="@+id/layoutBotonesPago"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@android:color/white"
        android:orientation="vertical"
        android:padding="18dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnRegistrarPago"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Registrar Pago"
            android:backgroundTint="#1976D2"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:padding="14dp"/>

        <Button
            android:id="@+id/btnNuevoPago"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nuevo Registro"
            android:backgroundTint="#4CAF50"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:padding="14dp"
            android:layout_marginTop="12dp"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
