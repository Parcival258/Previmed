<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- Tarjeta principal -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardAsesor"
        android:layout_width="389dp"
        android:layout_height="646dp"
        android:layout_marginHorizontal="24dp"
        android:backgroundTint="@color/white"
        android:padding="20dp"
        app:cardCornerRadius="34dp"
        app:cardElevation="14dp"
        android:layout_marginTop="20dp"
        app:cardUseCompatPadding="true"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="685dp"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <!-- FOTO GRANDE DEL ASESOR -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardFoto"
                android:layout_width="450dp"
                android:layout_height="400dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/borde_degradado"
                android:padding="10dp"
                app:cardCornerRadius="180dp"
                app:cardElevation="25dp"
                app:cardUseCompatPadding="true">

                <ImageView
                    android:id="@+id/imgAsesor"
                    android:layout_width="270dp"
                    android:layout_height="260dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/asesor_img" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="87dp" />
            </androidx.cardview.widget.CardView>

            <!-- ESPACIO -->

            <!-- TEXTO DE BIENVENIDA -->
            <TextView
                android:id="@+id/txtBienvenida"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bienvenido,"
                android:textColor="@android:color/black"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtNombre"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Roberto Sánchez"
                android:textColor="@android:color/black"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtCargo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Asesor Financiero Senior"
                android:textColor="#777"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/txtDescripcion"
                android:layout_width="match_parent"
                android:layout_height="75dp"
                android:gravity="center"
                android:padding="1dp"
                android:text="Listo para ayudarte a gestionar tus clientes y finanzas"
                android:textColor="#777"
                android:textSize="18sp" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- BOTÓN PAGOS PENDIENTES -->
    <Button
        android:id="@+id/btnPendientes"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:text="Pagos Pendientes"
        android:textColor="@android:color/white"
        android:textStyle="bold"
        android:background="@drawable/btn_blue_animado"
        android:layout_marginHorizontal="40dp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@+id/cardAsesor"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
