<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- Tarjeta principal -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardAsesor"
        android:layout_width="370dp"
        android:layout_height="550dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="120dp"
        android:backgroundTint="@color/white"
        android:padding="28dp"
        app:cardCornerRadius="34dp"
        app:cardElevation="14dp"
        app:cardUseCompatPadding="true"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <!-- Imagen más grande con borde degradado -->
            <FrameLayout
                android:layout_width="180dp"
                android:layout_height="170dp"
                android:layout_gravity="center"
                android:layout_marginTop="35dp"
                android:background="@drawable/borde_degradado"
                android:padding="6dp">

                <ImageView
                    android:id="@+id/imgAsesor"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/image_rounded"
                    android:padding="3dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/asesor_img" />
            </FrameLayout>

            <!-- Texto de bienvenida -->
            <TextView
                android:id="@+id/txtBienvenida"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="Bienvenido,"
                android:textColor="@android:color/black"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtNombre"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Roberto Sánchez"
                android:textColor="@android:color/black"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtCargo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Asesor Financiero Senior"
                android:textColor="#777"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/txtDescripcion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:gravity="center"
                android:padding="20dp"
                android:paddingHorizontal="20dp"
                android:text="Listo para ayudarte a gestionar tus clientes y finanzas"
                android:textColor="#777"
                android:textSize="20sp" />
        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- BOTÓN PAGOS PENDIENTES -->
    <Button
        android:id="@+id/btnPendientes"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:text="Pagos Pendientes"
        android:textColor="@android:color/white"
        android:textStyle="bold"
        android:background="@drawable/btn_blue_animado"
        android:layout_marginHorizontal="40dp"
        android:layout_marginTop="25dp"
        app:layout_constraintTop_toBottomOf="@+id/cardAsesor"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
