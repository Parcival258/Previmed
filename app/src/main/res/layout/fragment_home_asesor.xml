<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="#F4F9FF">

    <!-- 🔵 HEADER PRINCIPAL -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="150dp"
        android:background="@drawable/bg_header_contrato"
        android:orientation="vertical"
        android:padding="20dp"
        app:layout_constraintTop_toTopOf="parent">
    </LinearLayout>


    <!-- FONDO AZUL DETRÁS DEL CARD DEL ASESOR -->
    <LinearLayout
        android:id="@+id/header2"
        android:layout_width="0dp"
        android:layout_height="200dp"
        android:background="@drawable/bg_boton_azul"
        android:orientation="vertical"
        android:layout_marginTop="200dp"
        android:layout_marginHorizontal="24dp"
        android:padding="10dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />


    <!-- CARD DE PAGOS PENDIENTES -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardPagos"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="26dp"
        android:layout_marginTop="20dp"
        app:cardCornerRadius="18dp"
        app:cardElevation="7dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="110dp"
            android:orientation="horizontal"
            android:padding="20dp"
            android:gravity="center_vertical">

            <!-- ▼ COLUMNA IZQUIERDA -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <!-- TITULOS EN HORIZONTAL -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Pagos pendientes"
                        android:textColor="#FF0000"
                        android:textStyle="bold"
                        android:textSize="18sp"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="end"
                        android:text="Total"
                        android:textColor="#FF0000"
                        android:textStyle="bold"
                        android:textSize="18sp"/>
                </LinearLayout>

                <!-- VALORES EN HORIZONTAL -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp"
                    android:weightSum="2">

                    <TextView
                        android:id="@+id/txtPagosPendientes"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="0 pagos"
                        android:textColor="#007DFF"
                        android:textStyle="bold"
                        android:textSize="17sp"/>

                    <TextView
                        android:id="@+id/txtTotalPendiente"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="end"
                        android:text="$0"
                        android:textColor="#007DFF"
                        android:textStyle="bold"
                        android:textSize="17sp"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>


    <!-- 📘 RESTO IGUAL -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardAsesor"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="35dp"
        app:cardCornerRadius="22dp"
        app:cardElevation="6dp"
        android:padding="24dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <ImageView
                android:id="@+id/imgAsesor"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:background="@drawable/circle_white"
                android:scaleType="centerInside"
                android:src="@drawable/asesor_img"/>

            <TextView
                android:id="@+id/txtNombre"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Oscar Daza"
                android:textColor="#0A1A2A"
                android:textSize="22sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/txtCargo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Asesor Previmed"
                android:textColor="#4C9AF1"
                android:textSize="19sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/txtDescripcion"
                android:layout_width="330dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="19dp"
                android:gravity="center"
                android:lineSpacingExtra="6dp"
                android:text="Acompaño a los pacientes en el uso de la plataforma y en la gestión de sus servicios médicos a domicilio."
                android:textColor="#707A86"
                android:textStyle="bold"
                android:textSize="15sp"/>

            <TextView
                android:id="@+id/txtDescripcion2"
                android:layout_width="330dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="0dp"
                android:gravity="center"
                android:lineSpacingExtra="6dp"
                android:textStyle="bold"
                android:text="Brindo orientación, soporte y seguimiento para garantizar una atención médica eficiente, rápida y segura desde la app."
                android:textColor="#707A86"
                android:textSize="15sp"/>


            <Button
                android:id="@+id/btnPendientes"
                android:layout_width="315dp"
                android:layout_height="55dp"
                android:layout_marginTop="30dp"
                android:layout_marginBottom="36dp"
                android:background="@drawable/bg_boton_azul"
                android:drawableLeft="@drawable/pagos"
                android:drawablePadding="12dp"
                android:text="Ver Pagos Pendientes"
                android:textColor="@android:color/white"
                android:textStyle="bold"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
