<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="#F4F9FF">

    <!-- 🔵 HEADER SUPERIOR -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="150dp"
        android:background="@drawable/bg_header_contrato"
        android:orientation="vertical"
        android:padding="20dp"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 🔵 FONDO DETRÁS DEL CARD DEL ASESOR -->
    <LinearLayout
        android:id="@+id/header2"
        android:layout_width="0dp"
        android:layout_height="210dp"
        android:layout_marginTop="210dp"
        android:layout_marginHorizontal="24dp"
        android:background="@drawable/bg_azul_redondeado"
        android:padding="10dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 🔴 CARD PAGOS PENDIENTES -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardPagos"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="26dp"
        android:layout_marginTop="20dp"
        app:cardCornerRadius="22dp"
        app:cardElevation="10dp"
        app:cardUseCompatPadding="true"
        android:backgroundTint="#FFFFFF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:padding="22dp"
            android:orientation="vertical">

            <!-- TÍTULOS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Pagos pendientes"
                    android:textColor="#E53935"
                    android:textStyle="bold"
                    android:textSize="18sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="end"
                    android:text="Total"
                    android:textColor="#E53935"
                    android:textStyle="bold"
                    android:textSize="18sp" />
            </LinearLayout>

            <!-- VALORES -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp">

                <TextView
                    android:id="@+id/txtPagosPendientes"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="0 pagos"
                    android:textColor="#0C6CF0"
                    android:textStyle="bold"
                    android:textSize="17sp" />

                <TextView
                    android:id="@+id/txtTotalPendiente"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="end"
                    android:text="$0"
                    android:textColor="#0C6CF0"
                    android:textStyle="bold"
                    android:textSize="17sp" />
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- 🧑‍⚕️ CARD DEL ASESOR -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardAsesor"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="35dp"
        app:cardCornerRadius="26dp"
        app:cardElevation="8dp"
        android:padding="26dp"
        android:backgroundTint="#FFFFFF"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <FrameLayout
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:background="@drawable/circle_white">

                <ImageView
                    android:id="@+id/imgAsesor"
                    android:layout_width="150dp"
                    android:layout_height="150dp"
                    android:layout_gravity="center"
                    android:scaleType="centerCrop"
                    android:src="@drawable/asesor_img"
                    android:adjustViewBounds="true"/>
            </FrameLayout>

            <TextView
                android:id="@+id/txtNombre"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Oscar Daza"
                android:textColor="#0A1A2A"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtCargo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Asesor MediHome"
                android:textColor="#4C9AF1"
                android:textSize="19sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtDescripcion"
                android:layout_width="330dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="19dp"
                android:gravity="center"
                android:lineSpacingExtra="6dp"
                android:text="Acompaño a los pacientes en el uso de la plataforma y en la gestión de sus servicios médicos a domicilio."
                android:textColor="#707A86"
                android:textStyle="bold"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/txtDescripcion2"
                android:layout_width="330dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:lineSpacingExtra="6dp"
                android:textStyle="bold"
                android:text="Brindo orientación, soporte y seguimiento para garantizar una atención médica eficiente, rápida y segura desde la app."
                android:textColor="#707A86"
                android:textSize="15sp" />

            <!-- Botón -->
            <Button
                android:id="@+id/btnPendientes"
                android:layout_width="315dp"
                android:layout_height="55dp"
                android:layout_marginTop="30dp"
                android:layout_marginBottom="36dp"
                android:background="@drawable/bg_boton_azul"
                android:drawableLeft="@drawable/pagos"
                android:drawablePadding="12dp"
                android:text="Ver Pagos Pendientes"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
