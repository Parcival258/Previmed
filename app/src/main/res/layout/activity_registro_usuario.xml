<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="#F5F5F5"
    tools:context=".RegistroUsuario">

    <!-- 🔵 Barra superior -->
    <TextView
        android:id="@+id/tvTitulo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#2196F3"
        android:text="Registro de Paciente"
        android:textColor="@android:color/white"
        android:textSize="20sp"
        android:textStyle="bold"
        android:gravity="center"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 🧾 Contenido con scroll -->
    <ScrollView
        android:id="@+id/scrollPaciente"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitulo"
        app:layout_constraintBottom_toTopOf="@id/layoutBotones"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Campos de texto -->
            <EditText
                android:id="@+id/etNombre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nombre"
                android:inputType="textPersonName"
                android:background="@color/white"
                android:padding="10dp"
                android:layout_marginTop="8dp"/>

            <EditText
                android:id="@+id/etSegundoNombre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Segundo Nombre"
                android:inputType="textPersonName"
                android:background="@color/white"
                android:padding="10dp"
                android:layout_marginTop="8dp"/>

            <EditText
                android:id="@+id/etApellido"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Apellido"
                android:inputType="textPersonName"
                android:background="@color/white"
                android:padding="10dp"
                android:layout_marginTop="8dp"/>

            <EditText
                android:id="@+id/etSegundoApellido"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Segundo Apellido"
                android:inputType="textPersonName"
                android:background="@color/white"
                android:padding="10dp"
                android:layout_marginTop="8dp"/>

            <EditText
                android:id="@+id/etOcupacion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Ocupación"
                android:inputType="textPersonName"
                android:background="@color/white"
                android:padding="10dp"
                android:layout_marginTop="8dp"/>

            <!-- EPS -->
            <TextView
                android:text="EPS"
                android:textStyle="bold"
                android:textColor="#2196F3"
                android:paddingTop="16dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <Spinner
                android:id="@+id/spEps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Email"
                android:inputType="textEmailAddress"
                android:background="@color/white"
                android:padding="10dp"
                android:layout_marginTop="8dp"/>

            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Contraseña"
                android:inputType="textPassword"
                android:background="@color/white"
                android:padding="10dp"
                android:layout_marginTop="8dp"/>

            <!-- Tipo documento -->
            <TextView
                android:text="Tipo de Documento"
                android:textStyle="bold"
                android:textColor="#2196F3"
                android:paddingTop="16dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <Spinner
                android:id="@+id/spTipoDocumento"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <EditText
                android:id="@+id/etNumeroDocumento"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Número de Documento"
                android:inputType="number"
                android:background="@color/white"
                android:padding="10dp"
                android:layout_marginTop="8dp"/>

            <!-- Fecha de nacimiento -->
            <TextView
                android:text="Fecha de Nacimiento"
                android:textStyle="bold"
                android:textColor="#2196F3"
                android:paddingTop="16dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <EditText
                android:id="@+id/etFechaNacimiento"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Selecciona la fecha"
                android:focusable="false"
                android:clickable="true"
                android:background="@color/white"
                android:padding="10dp"
                android:layout_marginTop="8dp"/>

            <EditText
                android:id="@+id/etNumeroHijos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Número de Hijos"
                android:inputType="number"
                android:background="@color/white"
                android:padding="10dp"
                android:layout_marginTop="8dp"/>

            <EditText
                android:id="@+id/etEstrato"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Estrato"
                android:inputType="number"
                android:background="@color/white"
                android:padding="10dp"
                android:layout_marginTop="8dp"/>

            <!-- Autorización de datos -->
            <TextView
                android:text="¿Autoriza el uso de sus datos?"
                android:textStyle="bold"
                android:textColor="#2196F3"
                android:paddingTop="16dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <Spinner
                android:id="@+id/spAutorizacionDatos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <!-- Género -->
            <TextView
                android:text="Género"
                android:textStyle="bold"
                android:textColor="#2196F3"
                android:paddingTop="16dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <Spinner
                android:id="@+id/spGenero"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <!-- Rol -->
            <TextView
                android:text="Rol"
                android:textStyle="bold"
                android:textColor="#2196F3"
                android:paddingTop="16dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <Spinner
                android:id="@+id/spRol"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <!-- Plan -->
            <TextView
                android:text="Tipo de Plan"
                android:textStyle="bold"
                android:textColor="#2196F3"
                android:paddingTop="16dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <Spinner
                android:id="@+id/spPlan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <!-- Forma de pago -->
            <TextView
                android:text="Forma de Pago"
                android:textStyle="bold"
                android:textColor="#2196F3"
                android:paddingTop="16dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <Spinner
                android:id="@+id/spformapago"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <EditText
                android:id="@+id/etDireccion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Dirección Principal"
                android:inputType="textPostalAddress"
                android:background="@color/white"
                android:padding="10dp"
                android:layout_marginTop="8dp"/>

            <EditText
                android:id="@+id/etDireccionCobro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Dirección de Cobro"
                android:inputType="textPostalAddress"
                android:background="@color/white"
                android:padding="10dp"
                android:layout_marginTop="8dp"/>

            <!-- Estado civil -->
            <TextView
                android:text="Estado Civil"
                android:textStyle="bold"
                android:textColor="#2196F3"
                android:paddingTop="16dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <Spinner
                android:id="@+id/spEstadoCivil"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <!-- Progress oculto -->
            <ProgressBar
                android:id="@+id/pbLoading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone"
                style="?android:attr/progressBarStyleLarge"
                android:layout_marginTop="20dp"/>
        </LinearLayout>
    </ScrollView>

    <!-- 🟢 Zona inferior fija con botones -->
    <LinearLayout
        android:id="@+id/layoutBotones"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#F5F5F5"
        android:elevation="6dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnGuardar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Registrar"
            android:backgroundTint="#2196F3"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:padding="14dp"
            android:elevation="3dp"/>

        <Button
            android:id="@+id/btnSiguienteRegistro"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Siguiente"
            android:backgroundTint="#4CAF50"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:padding="14dp"
            android:elevation="3dp"
            android:layout_marginTop="10dp"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
