<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp"
    android:background="@drawable/card_info"
    android:orientation="vertical"
    android:layout_margin="12dp"
    android:elevation="6dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/Nombre1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Alejandro Campo Mendoza"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="#000000" />
    </RelativeLayout>

    <TextView
        android:id="@+id/textDoc"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Doc: 25736897"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/textDireccion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Dirección: Popayán-Cauca"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/textPlan"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Plan: Individual"
        android:textSize="14sp" />

    <ImageButton
        android:id="@+id/BotonMirarPac"
        android:layout_width="wrap_content"
        android:layout_height="26dp"
        android:background="@drawable/see"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="7dp"
        android:layout_gravity="right"/>
</LinearLayout>
