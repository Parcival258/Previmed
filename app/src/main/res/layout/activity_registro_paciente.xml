<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".controller.asesor.RegistroPaciente">

    <!-- Título -->
    <TextView
        android:id="@+id/tvTitulo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#2196F3"
        android:text="Registro de Paciente"
        android:textColor="@android:color/white"
        android:textSize="20sp"
        android:textStyle="bold"
        android:gravity="center"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Scroll para los campos -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitulo"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Nombre -->
            <EditText
                android:id="@+id/etNombre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nombre"
                android:inputType="textPersonName" />

            <!-- Apellido -->
            <EditText
                android:id="@+id/etApellido"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Apellido"
                android:inputType="textPersonName" />

            <!-- Email -->
            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Email"
                android:inputType="textEmailAddress" />

            <!-- Contraseña -->
            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Contraseña"
                android:inputType="textPassword" />

            <!-- Tipo de Documento -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tipo de Documento"
                android:textStyle="bold"
                android:paddingTop="12dp"/>
            <Spinner
                android:id="@+id/spTipoDocumento"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <!-- Número de Documento -->
            <EditText
                android:id="@+id/etNumeroDocumento"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Número de Documento"
                android:inputType="number" />

            <!-- Fecha de Nacimiento -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fecha de Nacimiento"
                android:textStyle="bold"
                android:paddingTop="12dp"/>
            <EditText
                android:id="@+id/etFechaNacimiento"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Selecciona la fecha"
                android:focusable="false"
                android:clickable="true" />

            <!-- Número de Hijos -->
            <EditText
                android:id="@+id/etNumeroHijos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Número de Hijos"
                android:inputType="number" />

            <!-- Estrato -->
            <EditText
                android:id="@+id/etEstrato"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Estrato"
                android:inputType="number" />

            <!-- Autorización de Datos -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="¿Autoriza el uso de sus datos?"
                android:textStyle="bold"
                android:paddingTop="12dp"/>
            <Spinner
                android:id="@+id/spAutorizacionDatos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <!-- Género -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Género"
                android:textStyle="bold"
                android:paddingTop="12dp"/>
            <Spinner
                android:id="@+id/spGenero"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rol"
                android:textStyle="bold"
                android:paddingTop="12dp"/>
            <Spinner
                android:id="@+id/spRol"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <!-- NUEVO: Spinner de Plan -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tipo de Plan"
                android:textStyle="bold"
                android:paddingTop="12dp"/>
            <Spinner
                android:id="@+id/spPlan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <!-- Dirección principal -->
            <EditText
                android:id="@+id/etDireccion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Dirección Principal"
                android:inputType="textPostalAddress" />

            <!-- Dirección de Cobro -->
            <EditText
                android:id="@+id/etDireccionCobro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Dirección de Cobro"
                android:inputType="textPostalAddress" />

            <!-- Estado Civil -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Estado Civil"
                android:textStyle="bold"
                android:paddingTop="12dp"/>
            <Spinner
                android:id="@+id/spEstadoCivil"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <!-- Botón Guardar -->
            <Button
                android:id="@+id/btnGuardar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Registrar"
                android:backgroundTint="#2196F3"
                android:textColor="@android:color/white"
                android:layout_marginTop="20dp" />

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
