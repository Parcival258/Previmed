<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"


    android:orientation="vertical"

    android:background="@color/white"
    tools:context=".controller.asesor.fragmentAsesor.PagosAsesorFragment">

    <!-- Encabezado -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:background="@color/AZUL_GENERAL"
        android:padding="16dp">

        <TextView
            android:id="@+id/textView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pagos"

            android:textColor="@color/black"
            android:textSize="30dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.008" />

            android:textColor="@color/white"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center" />
    </RelativeLayout>

    <!-- Contenedor blanco redondeado -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="@drawable/rounded_top_white"
        android:padding="16dp"
        android:layout_marginTop="-20dp">


        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_pagos_asesor"
            android:layout_width="match_parent"
            android:layout_height="match_parent"

            android:layout_marginTop="50dp"
            android:layout_marginBottom="60dp"
            android:padding="10dp" />

        <Button
            android:id="@+id/btn_ir_pagos_add"
            android:layout_width="60dp"
            android:layout_height="65dp"
            android:backgroundTint="@color/black"
            android:text="+"
            android:textColor="@color/white"
            android:textSize="30dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="1.0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.876" />

    </androidx.constraintlayout.widget.ConstraintLayout>

            android:padding="10dp"
            android:clipToPadding="false" />
    </LinearLayout>


    <!-- Botón flotante -->
    <Button
        android:id="@+id/btn_ir_pagos_add"
        android:layout_width="65dp"
        android:layout_height="65dp"
        android:layout_gravity="end"
        android:layout_margin="16dp"
        android:backgroundTint="@color/AZUL_GENERAL"
        android:text="+"
        android:textColor="@color/white"
        android:textSize="30sp" />
</LinearLayout>
