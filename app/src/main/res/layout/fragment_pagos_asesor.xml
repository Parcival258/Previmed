<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fitsSystemWindows="true"
    tools:context=".controller.asesor.fragmentAsesor.PagosAsesorFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingTop="16dp"
        android:paddingHorizontal="16dp">

        <!-- 🏷️ Título -->
        <TextView
            android:id="@+id/tvTituloPagos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pagos"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:gravity="center"
            android:paddingVertical="10dp" />

        <!-- 🔍 Barra de búsqueda moderna -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_search_box"
            android:paddingHorizontal="16dp"
            android:layout_marginVertical="12dp"
            android:elevation="6dp"
            android:clipToOutline="true">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@android:drawable/ic_menu_search"
                android:contentDescription="Buscar"
                app:tint="@color/AZUL_GENERAL" />

            <EditText
                android:id="@+id/etBuscarPago"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Buscar pago..."
                android:background="@android:color/transparent"
                android:textColor="@color/black"
                android:textColorHint="#9E9E9E"
                android:paddingStart="10dp"
                android:textSize="16sp"
                android:imeOptions="actionSearch"
                android:singleLine="true" />
        </LinearLayout>

        <!-- 📋 Lista de pagos -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_pagos_asesor"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="8dp" />

        <!-- ➕ Botón flotante -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:padding="16dp">

            <Button
                android:id="@+id/btn_ir_pagos_add"
                android:layout_width="65dp"
                android:layout_height="65dp"
                android:backgroundTint="@color/AZUL_GENERAL"
                android:text="+"
                android:textColor="@color/white"
                android:textSize="30sp"
                android:elevation="6dp" />
        </LinearLayout>

    </LinearLayout>

</FrameLayout>
