<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="8dp"
    android:layout_marginHorizontal="16dp"
    card_view:cardCornerRadius="16dp"
    card_view:cardElevation="6dp"
    android:background="@android:color/transparent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- 🧍 Imagen del paciente -->
        <ImageView
            android:id="@+id/icon_user"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@drawable/logo"
            android:scaleType="centerCrop"
            android:background="@drawable/circle_background"
            android:padding="4dp" />

        <!-- 📋 Datos del paciente y la visita -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="16dp">

            <!-- Nombre del paciente -->
            <TextView
                android:id="@+id/txtPacienteHistorial"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👤 Nombre Paciente"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:paddingVertical="2dp"/>

            <!-- Descripción -->
            <TextView
                android:id="@+id/txtDescripcionHistorial"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🧾 Descripción"
                android:textSize="15sp"
                android:textColor="#555555"
                android:paddingVertical="2dp"/>

            <!-- Fecha -->
            <TextView
                android:id="@+id/txtFechaHistorial"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📅 Fecha"
                android:textSize="14sp"
                android:textColor="#666666"
                android:paddingVertical="2dp"/>

            <!-- Dirección -->
            <TextView
                android:id="@+id/txtDireccionHistorial"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📍 Dirección"
                android:textSize="14sp"
                android:textColor="#666666"
                android:paddingVertical="2dp"/>

            <!-- Barrio -->
            <TextView
                android:id="@+id/txtBarrioHistorial"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏘 Barrio"
                android:textSize="14sp"
                android:textColor="#666666"
                android:paddingVertical="2dp"/>

            <!-- Teléfono -->
            <TextView
                android:id="@+id/txtTelefonoHistorial"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="☎️ Teléfono"
                android:textSize="14sp"
                android:textColor="#666666"
                android:paddingVertical="2dp"/>

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
