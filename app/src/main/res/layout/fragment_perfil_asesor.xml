<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FB">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ENCABEZADO PROFESIONAL / DISEÑO NUEVO -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:orientation="vertical"
            android:padding="28dp"
            android:background="@color/Azul_Prevemed">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- FOTO PROFESIONAL CON GLOW -->
                <FrameLayout
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:background="@drawable/bg_card_rounded"
                    android:padding="10dp"
                    android:layout_marginEnd="20dp">

                    <ImageView
                        android:id="@+id/iv_perfil_asesor"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:background="@drawable/asesor_img"
                        android:clipToOutline="true" />
                </FrameLayout>


                <!-- INFORMACIÓN DEL ASESOR -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_weight="1">

                    <TextView
                        android:id="@+id/tv_nombre_asesor"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Alberto Lasso"
                        android:textColor="@android:color/white"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.02" />

                    <TextView
                        android:id="@+id/tv_cargo_asesor"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Asesor Financiero Senior"
                        android:textColor="#DDE3FF"
                        android:textSize="15sp"
                        android:layout_marginTop="3dp" />

                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/tv_subtitulo_asesor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tu seguridad financiera es mi prioridad."
                android:textColor="#F7F9FF"
                android:textSize="18sp"
                android:alpha="0.92"
                android:layout_marginTop="10dp"/>
        </LinearLayout>


        <!-- CONTENEDOR GENERAL -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- TARJETA PLANES -->
            <androidx.cardview.widget.CardView
                android:id="@+id/btn_planes_perfil"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="15dp"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="18dp"
                app:cardElevation="8dp"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="18dp">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_icon_circle"
                        android:padding="8dp"
                        android:src="@drawable/ic_ver_planes" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="Planes"
                        android:textColor="#1A1A1A"
                        android:textSize="18sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- TARJETA BARRIOS -->
            <androidx.cardview.widget.CardView
                android:id="@+id/btn_barrios_perfil"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="15dp"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="18dp"
                app:cardElevation="8dp"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="18dp">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_icon_circle"
                        android:padding="8dp"
                        android:src="@drawable/ic_barrios_asesor" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="Barrios"
                        android:textColor="#1A1A1A"
                        android:textSize="18sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- TARJETA CONTRATOS -->
            <androidx.cardview.widget.CardView
                android:id="@+id/btn_contratos_perfil"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="15dp"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="18dp"
                app:cardElevation="8dp"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="18dp">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_icon_circle"
                        android:padding="8dp"
                        android:src="@drawable/ic_contrato" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="Contratos"
                        android:textColor="#1A1A1A"
                        android:textSize="18sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- TARJETA CERRAR SESIÓN -->
            <androidx.cardview.widget.CardView
                android:id="@+id/btn_logout_perfil"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="5dp"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="18dp"
                app:cardElevation="8dp"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="18dp">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_icon_circle_red"
                        android:padding="8dp"
                        android:src="@drawable/ic_logout" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="Cerrar sesión"
                        android:textColor="@android:color/holo_red_dark"
                        android:textSize="18sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </LinearLayout>

</ScrollView>
