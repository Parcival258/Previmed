<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="#F5F7FB">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ENCABEZADO PROFESIONAL / DISEÑO NUEVO -->


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="184dp"
            android:background="@drawable/bg_header_contrato"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="16dp"
            android:paddingTop="40dp">

            <!-- FOTO + NOMBRE + CARGO (alineado igual al estilo contrato) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- FOTO PROFESIONAL -->
                <FrameLayout
                    android:layout_width="75dp"
                    android:layout_height="75dp"
                    android:layout_marginEnd="16dp"
                    android:background="@drawable/circle_white"
                    android:padding="10dp">

                    <ImageView
                        android:id="@+id/iv_perfil_asesor"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/asesor_img"
                        android:clipToOutline="true"
                        android:scaleType="centerCrop" />
                </FrameLayout>

                <!-- INFORMACIÓN DEL ASESOR -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_nombre_asesor"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:letterSpacing="0.02"
                        android:text="Alberto Lasso"
                        android:textColor="@android:color/white"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_cargo_asesor"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Asesor Financiero Senior"
                        android:textColor="#DDE3FF"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- SUBTÍTULO (alineado como el texto del encabezado contrato) -->
            <TextView
                android:id="@+id/tv_subtitulo_asesor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:alpha="0.92"
                android:text="Tu seguridad financiera es mi prioridad."
                android:textColor="#F7F9FF"
                android:textSize="16sp" />
        </LinearLayout>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- TARJETA PLANES -->
            <androidx.cardview.widget.CardView
                android:id="@+id/btn_planes_perfil"
                android:layout_width="380dp"
                android:layout_height="100dp"
                android:layout_marginBottom="2dp"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="18dp"
                app:cardElevation="8dp"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="18dp">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_icon_circle"
                        android:padding="8dp"
                        android:src="@drawable/ic_ver_planes" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="Planes"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A"
                        android:textSize="18sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- TARJETA BARRIOS -->
            <androidx.cardview.widget.CardView
                android:id="@+id/btn_barrios_perfil"
                android:layout_width="380dp"
                android:layout_height="100dp"
                android:layout_marginBottom="2dp"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="18dp"
                app:cardElevation="8dp"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="18dp">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_icon_circle"
                        android:padding="8dp"
                        android:src="@drawable/ic_barrios_asesor" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="Barrios"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A"
                        android:textSize="18sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- TARJETA CONTRATOS -->
            <androidx.cardview.widget.CardView
                android:id="@+id/btn_contratos_perfil"
                android:layout_width="380dp"
                android:layout_height="100dp"
                android:layout_marginBottom="2dp"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="18dp"
                app:cardElevation="8dp"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="18dp">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_icon_circle"
                        android:padding="8dp"
                        android:src="@drawable/ic_contrato" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="Contratos"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A"
                        android:textSize="18sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- TARJETA CERRAR SESIÓN -->
            <androidx.cardview.widget.CardView
                android:id="@+id/btn_logout_perfil"
                android:layout_width="380dp"
                android:layout_height="100dp"
                android:layout_marginBottom="2dp"
                android:clickable="true"
                android:focusable="true"
                app:cardCornerRadius="18dp"
                app:cardElevation="8dp"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="18dp">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_icon_circle_red"
                        android:padding="8dp"
                        android:src="@drawable/ic_logout" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="Cerrar sesión"
                        android:textStyle="bold"
                        android:textColor="@android:color/holo_red_dark"
                        android:textSize="18sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </LinearLayout>

</ScrollView>
