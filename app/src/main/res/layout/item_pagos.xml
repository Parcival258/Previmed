<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/cardRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="20dp"
    android:layout_margin="10dp"
    android:background="@drawable/card_info"
    android:orientation="vertical"
    android:layout_marginBottom="5dp"
    android:layout_marginTop="10dp">

    <ImageButton
        android:id="@+id/img_pago_eviencia"
        android:layout_width="120dp"
        android:layout_height="100dp"
        android:layout_gravity="center"
        android:background="@drawable/ic_img" />

    <!-- Info siempre visible -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="20dp"
        android:paddingHorizontal="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:textColor="@color/black"
            android:text="N° Recibo" />

        <TextView
            android:id="@+id/tvNumRecibo"
            android:layout_weight="2"
            android:gravity="end"
            android:textColor="@color/black"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="22" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:textColor="@color/black"
            android:text="N° Contrato" />

        <TextView
            android:id="@+id/tvNumContrato"
            android:layout_weight="2"
            android:gravity="end"
            android:textColor="@color/black"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="45" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:textColor="@color/black"
            android:text="Titular" />

        <TextView
            android:id="@+id/tvTitular"
            android:layout_weight="2"
            android:gravity="end"
            android:textColor="@color/black"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="jsjd" />

    </LinearLayout>

    <!-- Layout que se expandirá/colapsará -->
    <LinearLayout
        android:id="@+id/expandableLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:paddingTop="8dp">

        <TextView
            android:id="@+id/tvCobrador"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cobrador" />

        <TextView
            android:id="@+id/tvFechaCobro"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Fecha de Cobro" />

        <TextView
            android:id="@+id/tvFechaInicio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Fecha Inicio" />

        <TextView
            android:id="@+id/tvFechaFin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Fecha Fin" />

        <TextView
            android:id="@+id/tvFormaPago"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Forma de Pago" />

        <TextView
            android:id="@+id/tvMonto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Monto" />
    </LinearLayout>
</LinearLayout>
