<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/barriosAsesorFragment"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white"
    tools:context=".controller.asesor.fragmentAsesor.BarriosAsesorFragment">

    <!-- Encabezado -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="160dp"
        android:background="@color/AZUL_GENERAL"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvTituloBarrios"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Barrios"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold" />


    </RelativeLayout>

    <!-- Contenedor blanco redondeado -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="@drawable/rounded_top_white"
        android:padding="16dp"
        android:layout_marginTop="-20dp">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerbarrios_asesor"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:padding="12dp" />

    </LinearLayout>
</LinearLayout>
