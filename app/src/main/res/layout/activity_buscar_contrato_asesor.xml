<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="@android:color/white">

    <!-- SearchView -->
    <androidx.appcompat.widget.SearchView
        android:id="@+id/search_view"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:queryHint="Buscar por cédula o nombre"
        android:background="@drawable/search_view_background"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp" />

    <!-- Botón Ver contrato -->
    <Button
        android:id="@+id/btn_ver_contrato"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:text="Ver contrato"
        android:textAllCaps="false"
        android:textSize="16sp"
        android:backgroundTint="@color/Azul_Prevemed"
        android:textColor="@android:color/white"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintBottom_toTopOf="@id/btn_imprimir_contrato"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="12dp"/>

    <!-- Botón Imprimir contrato -->
    <Button
        android:id="@+id/btn_imprimir_contrato"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:text="Imprimir contrato"
        android:textAllCaps="false"
        android:textSize="16sp"
        android:backgroundTint="@color/Azul_Prevemed"
        android:textColor="@android:color/white"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="16dp"/>


    <!-- RecyclerView ocupa todo el espacio entre el SearchView y los botones -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_personas"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/search_view"
        app:layout_constraintBottom_toTopOf="@id/btn_ver_contrato"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"/>
</androidx.constraintlayout.widget.ConstraintLayout>
