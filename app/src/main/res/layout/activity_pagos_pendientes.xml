<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- 🏷️ TÍTULO -->
    <TextView
        android:id="@+id/tvTituloPagos"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Pagos"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:gravity="center"
        android:paddingVertical="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp"
        android:layout_marginHorizontal="16dp" />

    <!-- 🔍 BARRA DE BÚSQUEDA -->
    <LinearLayout
        android:id="@+id/barraBusqueda"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_search_box"
        android:paddingHorizontal="16dp"
        android:elevation="6dp"
        android:clipToOutline="true"
        android:layout_marginTop="12dp"
        android:layout_marginHorizontal="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvTituloPagos"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@android:drawable/ic_menu_search"
            android:contentDescription="Buscar"
            app:tint="@color/AZUL_GENERAL" />

        <EditText
            android:id="@+id/etBuscarPago"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Buscar pago..."
            android:background="@android:color/transparent"
            android:textColor="@color/black"
            android:textColorHint="#9E9E9E"
            android:paddingStart="10dp"
            android:textSize="16sp"
            android:imeOptions="actionSearch"
            android:singleLine="true" />
    </LinearLayout>

    <!-- 📋 LISTA DE PAGOS -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_pagos_asesor"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/barraBusqueda"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="10dp" />

    <!-- ➕ BOTÓN FLOTANTE -->
    <Button
        android:id="@+id/btn_ir_pagos_add"
        android:layout_width="60dp"
        android:layout_height="70dp"
        android:text="+"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:backgroundTint="#457B9D"
        android:elevation="8dp"
        android:stateListAnimator="@null"
        android:layout_marginEnd="25dp"
        android:layout_marginBottom="80dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
