<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    tools:context=".controller.pacientes.fragmentBeneficiario.ContratoBeneficiarioFragment">

    <LinearLayout
        android:layout_width="411dp"
        android:layout_height="114dp"
        android:background="@drawable/esquinas_redondeadas"
        android:orientation="vertical"
        android:gravity="bottom|center_horizontal"
        >

        <TextView
            android:id="@+id/contratobenfeciario"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:elevation="2dp"
            android:fontFamily="sans-serif-medium"
            android:padding="8dp"
            android:text="¡Tu Contrato!"
            android:textColor="@color/white"
            android:textSize="24sp" />

</LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="16dp">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/verContrato"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="66dp"
            android:background="@drawable/btn_degradado_selector"
            android:text="Ver Contrato"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/DescargarContrato"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/btn_degradado_selector"
            android:text="Descargar Contrato"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>