<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".controller.asesor.AsociarBeneficiario">

    <!-- 🔵 TÍTULO -->
    <TextView
        android:id="@+id/tvTitulo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Asociar Beneficiario"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:gravity="center"
        android:paddingVertical="18dp"
        android:background="@color/white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- 📜 CONTENIDO -->
    <ScrollView
        android:id="@+id/scrollContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="16dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/tvTitulo"
        app:layout_constraintBottom_toTopOf="@id/layoutBotones"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 🧾 TARJETA REDONDEADA -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_formulario"
                android:orientation="vertical"
                android:padding="20dp"
                android:elevation="10dp"
                android:layout_marginHorizontal="6dp"
                android:layout_marginTop="10dp">

                <!-- TITULAR -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Seleccionar Titular"
                    android:textColor="@color/AZUL_GENERAL"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:paddingBottom="8dp"/>

                <Spinner
                    android:id="@+id/spTitular"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/input_style"
                    android:padding="14dp"/>

                <!-- BENEFICIARIO -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Seleccionar Beneficiario"
                    android:textColor="@color/AZUL_GENERAL"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:paddingTop="20dp"
                    android:paddingBottom="8dp"/>

                <!-- 💬 BUSCADOR -->
                <EditText
                    android:id="@+id/etBuscarBeneficiario"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="Buscar beneficiario..."
                    android:background="@drawable/input_style"
                    android:drawableStart="@android:drawable/ic_menu_search"
                    android:padding="14dp"
                    android:inputType="text"
                    android:layout_marginBottom="10dp"/>

                <Spinner
                    android:id="@+id/spBeneficiario"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/input_style"
                    android:padding="14dp"/>

                <!-- LOADING -->
                <ProgressBar
                    android:id="@+id/progressBar"
                    style="?android:attr/progressBarStyleLarge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="20dp"
                    android:visibility="gone"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- 🔘 BOTONES -->
    <LinearLayout
        android:id="@+id/layoutBotones"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@color/white"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnAsociar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Registrar Asociación"
            android:textStyle="bold"
            android:padding="14dp"
            android:textColor="@android:color/white"
            android:backgroundTint="@color/AZUL_GENERAL"/>

        <Button
            android:id="@+id/btnOmitir"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Siguiente"
            android:textStyle="bold"
            android:padding="14dp"
            android:textColor="@android:color/white"
            android:backgroundTint="#4CAF50"
            android:layout_marginTop="12dp"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
