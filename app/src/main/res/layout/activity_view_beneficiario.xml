<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF"
    tools:context=".controller.pacientes.ViewBeneficiario">

    <!-- CONTENEDOR DE FRAGMENTS: ocupa todo el espacio menos el navbar -->
    <FrameLayout
        android:id="@+id/paciente_nav"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />


    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation_pac"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:elevation="8dp"
        android:translationZ="8dp"

        app:menu="@menu/bottom_pac_menu"
        app:itemIconSize="26dp"
        app:labelVisibilityMode="selected"
        app:itemActiveIndicatorStyle="@style/App.Custom.Indicator" />

</LinearLayout>