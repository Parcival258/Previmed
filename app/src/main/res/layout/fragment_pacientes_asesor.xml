<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="10dp"
    android:background="#F1FAEE">

    <!-- SearchView arriba -->
    <SearchView
        android:id="@+id/btn_Buscar_Usu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        android:background="#457B9D"
        android:elevation="6dp"
        android:iconifiedByDefault="false" />

    <!-- RecyclerView debajo del SearchView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerPacientes"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="80dp"
        android:padding="12dp" />


    <Button
        android:id="@+id/BotonAgUsuario"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:layout_marginBottom="140dp"
        android:layout_gravity="bottom|end"
        android:backgroundTint="#457B9D"
        android:text="+"
        android:textColor="#FFFFFF"
        android:textSize="24sp" />

</FrameLayout>

