<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fitsSystemWindows="true"
    tools:context=".controller.asesor.PacientesView">

    <!-- 🔵 HEADER SUPERIOR CON TITULO (ESTILO PAGOS) -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:orientation="vertical"
        android:background="@drawable/bg_header_contrato"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvTituloPacientes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pacientes"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:gravity="center"
            android:paddingVertical="10dp"/>
    </LinearLayout>

    <!-- CONTENIDO DEBAJO DEL HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingTop="110dp"
        android:paddingHorizontal="16dp">

        <!-- 🔍 BUSCADOR (PEGADO TAL CUAL AL DE PAGOS) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_search_box"
            android:paddingHorizontal="16dp"
            android:layout_marginVertical="12dp"
            android:elevation="6dp"
            android:clipToOutline="true">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@android:drawable/ic_menu_search"
                android:contentDescription="Buscar"
                app:tint="@color/AZUL_GENERAL" />

            <EditText
                android:id="@+id/btn_Buscar_Usu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Buscar paciente..."
                android:background="@android:color/transparent"
                android:textColor="@color/black"
                android:textColorHint="#9E9E9E"
                android:paddingStart="10dp"
                android:textSize="16sp"
                android:imeOptions="actionSearch"
                android:singleLine="true" />
        </LinearLayout>

        <!-- 📋 LISTA DE PACIENTES -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerPacientes"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="8dp"
            android:paddingHorizontal="4dp" />

    </LinearLayout>

    <!-- ➕ BOTÓN FLOTANTE -->
    <Button
        android:id="@+id/btn_agregarPacientess"
        android:layout_width="60dp"
        android:layout_height="70dp"
        android:text="+"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:backgroundTint="#457B9D"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="25dp"
        android:layout_marginBottom="80dp"
        android:elevation="8dp"
        android:shape="oval"
        android:stateListAnimator="@null"/>

</FrameLayout>
