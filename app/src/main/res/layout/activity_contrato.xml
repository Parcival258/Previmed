<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".controller.asesor.ContratoActivity">

    <!-- 🔵 HEADER SUPERIOR -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@drawable/bg_header_contrato"
        android:orientation="vertical"
        android:padding="20dp"
        app:layout_constraintTop_toTopOf="parent">

        <!-- TÍTULO dentro del header -->
        <TextView
            android:id="@+id/tvTituloContrato"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Registro de Contrato"
            android:textSize="26sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textColor="@android:color/white"
            android:padding="6dp"/>
    </LinearLayout>

    <!-- 📜 SCROLL PRINCIPAL -->
    <ScrollView
        android:id="@+id/scrollContrato"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="16dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toTopOf="@id/layoutBotones"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="20dp">

            <!-- 🧾 TARJETA REDONDEADA -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_formulario"
                android:padding="20dp"
                android:elevation="10dp"
                android:clipToPadding="false"
                android:layout_marginHorizontal="6dp"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="20dp">

                <!-- Firma -->
                <EditText
                    android:id="@+id/etFirma"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="Firma (ej: firma1, firma2...)"
                    android:background="@drawable/input_style"
                    android:padding="14dp"
                    android:textColor="@color/black"
                    android:textColorHint="#9E9E9E"/>

                <!-- Número de contrato -->
                <EditText
                    android:id="@+id/etNumeroContrato"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="Número de Contrato"
                    android:background="@drawable/input_style"
                    android:padding="14dp"
                    android:layout_marginTop="12dp"/>

                <!-- Fecha inicio -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fecha Inicio del Contrato"
                    android:textColor="@color/AZUL_GENERAL"
                    android:textStyle="bold"
                    android:layout_marginTop="18dp"/>

                <EditText
                    android:id="@+id/etFechaInicioContrato"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="Selecciona la fecha"
                    android:focusable="false"
                    android:background="@drawable/input_style"
                    android:padding="14dp"
                    android:layout_marginTop="12dp"/>

                <!-- Fecha fin -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fecha Fin del Contrato"
                    android:textColor="@color/AZUL_GENERAL"
                    android:textStyle="bold"
                    android:layout_marginTop="18dp"/>

                <EditText
                    android:id="@+id/etFechaFinContrato"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="Selecciona la fecha"
                    android:focusable="false"
                    android:background="@drawable/input_style"
                    android:padding="14dp"
                    android:layout_marginTop="12dp"/>

                <!-- ID Contrato -->
                <TextView
                    android:id="@+id/tvIdMembresia"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ID Contrato: --"
                    android:textColor="#757575"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:paddingTop="16dp"
                    android:visibility="gone"
                    android:textSize="16sp"/>

                <!-- Loading -->
                <ProgressBar
                    android:id="@+id/pbLoading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    android:layout_gravity="center"
                    android:layout_marginTop="20dp"
                    style="?android:attr/progressBarStyleLarge"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- 🔘 BOTONES INFERIORES -->
    <LinearLayout
        android:id="@+id/layoutBotones"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@color/white"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnRegistrarContrato"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Registrar Contrato"
            android:textStyle="bold"
            android:backgroundTint="@color/AZUL_GENERAL"
            android:textColor="@android:color/white"
            android:padding="14dp"/>

        <Button
            android:id="@+id/btnSiguiente"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Siguiente"
            android:textStyle="bold"
            android:backgroundTint="#4CAF50"
            android:textColor="@android:color/white"
            android:padding="14dp"
            android:layout_marginTop="12dp"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
