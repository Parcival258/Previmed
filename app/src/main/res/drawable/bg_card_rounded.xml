<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Sombra externa suave -->
    <item>
        <shape android:shape="oval">
            <solid android:color="@color/Azul_Prevemed" /> <!-- Sombra suave negra con transparencia -->

            <size
                android:width="130dp"
                android:height="130dp" />
        </shape>
    </item>

    <!-- Círculo principal -->
    <item
        android:left="5dp"
        android:top="5dp"
        android:right="5dp"
        android:bottom="5dp">

        <shape android:shape="oval">

            <!-- Color sólido -->
            <solid android:color="@color/Azul_Prevemed" />

            <!-- Borde -->
            <stroke
                android:width="4dp"
                android:color="#72C1FF" />

            <!-- Tamaño -->
            <size
                android:width="120dp"
                android:height="120dp" />
        </shape>

    </item>

</layer-list>
