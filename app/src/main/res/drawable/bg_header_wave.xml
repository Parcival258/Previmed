<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Fondo azul oscuro -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#0B4F8C" />
        </shape>
    </item>

    <!-- Óvalo grande central (detrás del logo) DIFUMINADO y un poco más suave -->
    <item android:gravity="center_horizontal|center_vertical">
        <shape android:shape="oval">
            <size
                android:width="420dp"
                android:height="260dp" />
            <gradient
                android:type="radial"
                android:gradientRadius="210dp"
                android:centerX="0.5"
                android:centerY="0.5"
                android:startColor="#B01565C0"
                android:centerColor="#661565C0"
                android:endColor="#001565C0" />
        </shape>
    </item>

    <!-- Burbuja arriba-izquierda (azul claro difuminado) -->
    <item
        android:gravity="top|left"
        android:top="32dp"
        android:left="-40dp">
        <shape android:shape="oval">
            <size
                android:width="220dp"
                android:height="140dp" />
            <gradient
                android:type="radial"
                android:gradientRadius="110dp"
                android:centerX="0.5"
                android:centerY="0.5"
                android:startColor="#CC42A5F5"
                android:centerColor="#8042A5F5"
                android:endColor="#0042A5F5" />
        </shape>
    </item>

    <!-- Burbuja arriba-derecha (azul muy claro difuminado, un poquito más arriba) -->
    <item
        android:gravity="top|right"
        android:top="12dp"
        android:right="-60dp">
        <shape android:shape="oval">
            <size
                android:width="180dp"
                android:height="110dp" />
            <gradient
                android:type="radial"
                android:gradientRadius="90dp"
                android:centerX="0.5"
                android:centerY="0.5"
                android:startColor="#CC90CAF9"
                android:centerColor="#8090CAF9"
                android:endColor="#0090CAF9" />
        </shape>
    </item>

    <!-- Burbuja abajo-derecha (azul medio difuminado) -->
    <item
        android:gravity="bottom|right"
        android:bottom="-30dp"
        android:right="-40dp">
        <shape android:shape="oval">
            <size
                android:width="240dp"
                android:height="150dp" />
            <gradient
                android:type="radial"
                android:gradientRadius="120dp"
                android:centerX="0.5"
                android:centerY="0.5"
                android:startColor="#CC1976D2"
                android:centerColor="#801976D2"
                android:endColor="#001976D2" />
        </shape>
    </item>

    <!-- Luz suave detrás del texto "Médicos a domicilio" -->
    <item
        android:gravity="center_horizontal|bottom"
        android:bottom="40dp">
        <shape android:shape="oval">
            <size
                android:width="260dp"
                android:height="90dp" />
            <gradient
                android:type="radial"
                android:gradientRadius="130dp"
                android:centerX="0.5"
                android:centerY="0.5"
                android:startColor="#CC64B5F6"
                android:centerColor="#8064B5F6"
                android:endColor="#0064B5F6" />
        </shape>
    </item>

</layer-list>